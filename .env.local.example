# === AI Provider ===
# どちらかを使う。AI_PROVIDER で切り替え。
AI_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 任意。モデルの上書き。未指定時はコード内のデフォルトを使う。
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-6

# === Database (Neon Postgres) ===
# 空でも動作する (DB 書き込みが no-op になるだけ)。
# Vercel Marketplace の Neon integration を使えば本番では自動注入される。
# ローカルは Neon の branch URL を貼る。
DATABASE_URL=

# === アクセスゲート（合言葉）===
# サイト全体に合言葉ゲートをかける。関係者用とゲスト（クライアント）用の2種類。
# どちらか一方でも設定するとゲート有効。両方空ならゲート無効（＝誰でもアクセス可）。
# 本番では Vercel の環境変数に設定すること（Gitには入れない）。
STAFF_PASSCODE=
GUEST_PASSCODE=
# 認証Cookieの署名用ランダム文字列（推奨。未設定なら合言葉から自動導出）。
# 例: `openssl rand -hex 32` の出力を貼る。
GATE_SECRET=

# === Workflow SDK ===
# Vercel 本番では自動設定される。ローカルでは workflow の local world が使われる。
# デバッグ用: `npx workflow web` でダッシュボードを開ける。
